# local | staging | production — selects the default URL set below when the
# corresponding NEXT_PUBLIC_*_URL / NEXT_PUBLIC_API_BASE_URL is not set.
NEXT_PUBLIC_APP_ENV="local"

NEXT_PUBLIC_APP_NAME="WPA Account"
NEXT_PUBLIC_BRAND_NAME="World Pet Association"
NEXT_PUBLIC_APP_TAGLINE="One account for all WPA pet platforms."
NEXT_PUBLIC_SUPPORT_EMAIL="support@worldpetassociation.com"

# This app's own public origin.
#   local:       http://localhost:5011
#   staging:     https://auth.staging.worldpetassociation.com
#   production:  https://auth.worldpetassociation.com
NEXT_PUBLIC_AUTH_WEB_URL="http://localhost:5011"
NEXT_PUBLIC_ADMIN_WEB_URL="http://localhost:5012"

# WPA Auth API base URL, including its version prefix. NEVER point this at
# worldpetassociation.com (the public brand site) — the API always lives on
# its own api.* subdomain.
#   local:       http://localhost:5010/api/v1
#   staging:     https://api.staging.worldpetassociation.com/api/v1
#   production:  https://api.worldpetassociation.com/api/v1
NEXT_PUBLIC_API_BASE_URL="http://localhost:5010/api/v1"

# Where to send an already-authenticated user with no explicit next/redirect target.
#   local:       http://localhost:5011/account
#   staging:     https://auth.staging.worldpetassociation.com/account
#   production:  https://auth.worldpetassociation.com/account
NEXT_PUBLIC_DEFAULT_REDIRECT_URL="http://localhost:5011/account"
